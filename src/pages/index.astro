---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import { getCollection } from "astro:content";
import { updates } from "@data/updates";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const linkedin = SOCIALS.find((s) => s.NAME === "Linkedln")?.HREF ?? "#";

function fmtMonth(d: Date): string {
  return new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' })
    .format(d)
    .replace(/^(\w+)/, '$1.');
}
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>

  <!-- ─── 1. HERO ─────────────────────────────────────────────────────── -->
  <Container>
    <section class="relative overflow-hidden" style="height: 60vh; min-height: 400px;">
      <img src="/images/hero-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />

      <!-- Text overlay — top right -->
      <div class="absolute top-4 right-4 z-10 max-w-[55%] rounded-lg bg-white/80 p-5 backdrop-blur-sm dark:bg-black/70">
        <h1 class="text-xl font-semibold text-[var(--heading-color)] dark:text-white">Welcome!</h1>
        <p class="mt-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
          Hi, I'm Yi-Hsin, thanks for visiting my website. I'm currently a MSECE student at CMU,
          for more information about me, you could go to the "about" section.
          Scroll down to explore the website and hope you find something interesting!
        </p>
      </div>
    </section>
  </Container>

  <!-- ─── 2. UPDATES ────────────────────────────────────────────────────── -->
  <!-- Edit entries in src/data/updates.ts -->
  <Container>
    <section class="py-14">
      <div class="flex flex-col gap-8 sm:flex-row">
        <div class="flex-shrink-0 sm:w-32">
          <h2 class="font-semibold text-[var(--heading-color)] dark:text-white">Updates</h2>
        </div>
        <div class="min-w-0 flex-1">
          {updates.length > 0 ? (
            <ul class="space-y-4">
              {updates.map((entry) => (
                <li>
                  <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:gap-3">
                    <span class="flex-shrink-0 text-xs tabular-nums text-gray-400">
                      <FormattedDate date={new Date(entry.date)} />
                    </span>
                    {entry.url ? (
                      <a href={entry.url} class="text-sm text-stone-800 hover:underline dark:text-white">
                        {entry.title}
                      </a>
                    ) : (
                      <span class="text-sm text-stone-800 dark:text-white/80">{entry.title}</span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-400">No updates yet.</p>
          )}
        </div>
      </div>
    </section>
  </Container>

  <!-- ─── 3. RECENT PROJECTS ────────────────────────────────────────────── -->
  <Container>
    <section class="py-8">
      <div class="mb-8">
        <h2 class="font-semibold text-[var(--heading-color)] dark:text-white">Recent Projects</h2>
        <a
          href="/projects"
          class="mt-2 inline-block text-xs text-gray-400 transition-colors hover:text-black dark:hover:text-white"
        >
          view all →
        </a>
      </div>
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          {projects.map((project, i) => {
            const rotations = ["-rotate-2", "rotate-1", "-rotate-1"];
            const rot = rotations[i % 3];
            return (
              <a
                href={`/projects/${project.id}`}
                class={`block ${rot} transition-transform duration-300 hover:rotate-0`}
              >
                <!-- Polaroid card -->
                <div class="bg-white p-3 pb-14 shadow-lg dark:bg-neutral-100">
                  {project.data.cover ? (
                    <img
                      src={project.data.cover}
                      alt={project.data.title}
                      class="aspect-square w-full object-cover"
                    />
                  ) : (
                    <div class="aspect-square w-full bg-gray-200 flex items-center justify-center">
                      <span class="text-gray-400 text-xs select-none">no image</span>
                    </div>
                  )}
                  <p class="mt-3 text-center truncate" style="font-family: 'Caveat', cursive; font-size: 1.1rem; color: #44403c;">
                    {project.data.shortTitle ?? project.data.title}
                  </p>
                  <p class="mt-0.5 text-center" style="font-family: 'Caveat', cursive; font-size: 0.9rem; color: #78716c;">
                    {fmtMonth(project.data.startDate ?? project.data.date)}&nbsp;–&nbsp;{project.data.endDate ? fmtMonth(project.data.endDate) : 'current'}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="text-sm text-gray-400">No projects yet.</p>
      )}
    </section>
  </Container>

  <!-- ─── 4. RECENT POSTS ─────────────────────────────────────────────── -->
  <Container>
    <section class="py-8">
      <div class="flex flex-col gap-8 sm:flex-row">
        <div class="flex-shrink-0 sm:w-32">
          <h2 class="font-semibold text-[var(--heading-color)] dark:text-white">Recent Posts</h2>
          <a
            href="/blog"
            class="mt-2 inline-block text-xs text-gray-400 transition-colors hover:text-black dark:hover:text-white"
          >
            view all →
          </a>
        </div>
        <div class="min-w-0 flex-1">
          {posts.length > 0 ? (
            <ul class="space-y-4">
              {posts.map((post) => (
                <li>
                  <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:gap-3">
                    <span class="flex-shrink-0 text-xs tabular-nums text-gray-400">
                      <FormattedDate date={post.data.date} />
                    </span>
                    <a
                      href={`/blog/${post.id}`}
                      class="text-sm text-stone-800 hover:underline dark:text-white"
                    >
                      {post.data.title}
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-400">No posts yet.</p>
          )}
        </div>
      </div>
    </section>
  </Container>

  <!-- ─── 5. DESK SCENE ─────────────────────────────────────────────────── -->
  <Container>
  <section class="relative" style="aspect-ratio: 16/7; min-height: 200px;">
    <img src="/images/desk-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />

    <!-- ── MONITOR: colored at rest → GIF + text on hover ────────────── -->
    <!-- Provide: public/images/desk/monitor.gif -->
    <div class="group/monitor absolute cursor-pointer" style="top: 12%; left: 38%; width: 30%;">
      <!-- Static PNG fades out on hover -->
      <img
        src="/images/desk/monitor.png"
        alt="monitor"
        class="w-full transition-opacity duration-300 group-hover/monitor:opacity-0"
      />
      <!-- GIF fades in on hover -->
      <img
        src="/images/desk/monitor.gif"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 w-full opacity-0 transition-opacity duration-300 group-hover/monitor:opacity-100"
      />
      <!-- Text box above — EDIT the text inside the <span> -->
      <div class="pointer-events-none absolute bottom-full left-0 right-0 mb-2 translate-y-1 text-center opacity-0 transition-all duration-300 group-hover/monitor:translate-y-0 group-hover/monitor:opacity-100">
        <span class="inline-block rounded bg-white/90 px-2 py-1 text-xs shadow">
          These are some photos from my hiking trips in Taiwan and Japan.
        </span>
      </div>
    </div>

    <!-- ── MUG: colored at rest → GIF + text above on hover ──────────── -->
    <!-- Provide: public/images/desk/mug.gif -->
    <div class="group/mug absolute cursor-pointer" style="bottom: 28%; right: 12%; width: 25%;">
      <!-- Static PNG fades out on hover -->
      <img
        src="/images/desk/mug.png"
        alt="mug"
        class="w-full transition-opacity duration-300 group-hover/mug:opacity-0"
      />
      <!-- GIF fades in on hover -->
      <img
        src="/images/desk/mug.gif"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 w-full opacity-0 transition-opacity duration-300 group-hover/mug:opacity-100"
      />
      <!-- Text box above — EDIT the text inside the <span> -->
      <div class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 translate-y-1 whitespace-nowrap opacity-0 transition-all duration-300 group-hover/mug:translate-y-0 group-hover/mug:opacity-100">
        <span class="inline-block rounded bg-white/90 px-2 py-1 text-xs shadow">
          Pudding! Will update this animation sometimes in the future.
        </span>
      </div>
    </div>

    <!-- ── LAMP: click toggle for glow on/off ───────────────────────── -->
    <!-- Provide: public/images/desk/lamp-lit.png (same crop as lamp.png, glow effect) -->
    <div class="absolute" style="top: 10%; left: 15%; width: 40%;">
      <img src="/images/desk/lamp.png" alt="lamp" class="w-full" />
      <!-- Glow overlay — opacity controlled by JS toggle -->
      <img
        src="/images/desk/lamp-lit.png"
        alt=""
        aria-hidden="true"
        id="lamp-glow"
        class="pointer-events-none absolute inset-0 w-full opacity-0 transition-opacity duration-500"
      />
      <!-- Toggle button — adjust top/left (% of the lamp div) to hit the right spot on the image -->
      <button
        id="lamp-toggle"
        aria-label="Toggle lamp"
        aria-pressed="false"
        class="absolute flex size-6 cursor-pointer items-center justify-center rounded-full border border-black/20 bg-white/80 text-xs shadow-sm transition-colors hover:bg-white"
        style="top: 86%; left: 4%;"
      >⏻</button>
    </div>
  </section>
  </Container>

  <!-- ─── 6. CONTACT ────────────────────────────────────────────────────── -->
  <Container>
    <section class="py-14 text-center">
      <h2 class="text-2xl font-semibold text-[var(--heading-color)] dark:text-white">Contact Me!</h2>
      <div class="mt-4 flex flex-col items-center gap-2 text-sm text-gray-500">
        <a
          href={`mailto:${SITE.EMAIL}`}
          class="transition-colors hover:text-black hover:underline dark:hover:text-white"
        >
          {SITE.EMAIL}
        </a>
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-black hover:underline dark:hover:text-white"
        >
          LinkedIn
        </a>
      </div>
    </section>
  </Container>

  <!-- Marker used by CSS and script to detect homepage -->
  <div data-homepage hidden></div>

</Layout>

<script>
  function initLampToggle() {
    const glow = document.getElementById("lamp-glow");
    const btn = document.getElementById("lamp-toggle");
    if (!glow || !btn) return;

    let lit = false;
    btn.addEventListener("click", () => {
      lit = !lit;
      (glow as HTMLElement).style.opacity = lit ? "0.75" : "0";
      btn.setAttribute("aria-pressed", String(lit));
      btn.style.color = lit ? "#f59e0b" : "";
    });
  }

  document.addEventListener("DOMContentLoaded", initLampToggle);
  document.addEventListener("astro:after-swap", initLampToggle);
</script>

<script is:inline>
  // Force light mode on the homepage — runs immediately after preloadTheme()
  // and after each view-transition swap back to this page.
  function forceLight() {
    document.documentElement.classList.remove("dark");
  }

  forceLight();

  document.addEventListener("DOMContentLoaded", function () {
    // init() in Head.astro re-applies the user's stored theme synchronously.
    // A microtask queued here runs after all DOMContentLoaded handlers finish,
    // removing dark again before the first paint.
    Promise.resolve().then(forceLight);
  });

  document.addEventListener("astro:after-swap", function () {
    if (document.querySelector("[data-homepage]")) {
      Promise.resolve().then(forceLight);
    }
  });
</script>

