---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const linkedin = SOCIALS.find((s) => s.NAME === "Linkedln")?.HREF ?? "#";
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>

  <!-- ─── 1. HERO ─────────────────────────────────────────────────────── -->
  <Container>
    <section class="relative overflow-hidden" style="height: 60vh; min-height: 400px;">
      <img src="/images/hero-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />

      <!-- Text overlay — top right -->
      <div class="absolute top-4 right-4 z-10 max-w-[55%] rounded-lg bg-white/80 p-5 backdrop-blur-sm dark:bg-black/70">
        <h1 class="text-xl font-semibold text-black dark:text-white">{SITE.TITLE}</h1>
        <p class="mt-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
          Hi, I'm Yi-Hsin — an EE-background researcher and developer.
        </p>
      </div>
    </section>
  </Container>

  <!-- ─── 2. UPDATES ────────────────────────────────────────────────────── -->
  <Container>
    <section class="py-14">
      <div class="flex flex-col gap-8 sm:flex-row">
        <div class="flex-shrink-0 sm:w-32">
          <h2 class="font-semibold text-black dark:text-white">Updates</h2>
          <a
            href="/blog"
            class="mt-2 inline-block text-xs text-gray-400 transition-colors hover:text-black dark:hover:text-white"
          >
            view all →
          </a>
        </div>
        <div class="min-w-0 flex-1">
          {posts.length > 0 ? (
            <ul class="space-y-4 border-l border-black/20 pl-5 dark:border-white/20">
              {posts.map((post) => (
                <li class="relative">
                  <span class="absolute -left-[0.32rem] top-[0.38rem] h-2 w-2 rounded-full bg-black/25 dark:bg-white/30" />
                  <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:gap-3">
                    <span class="flex-shrink-0 text-xs tabular-nums text-gray-400">
                      <FormattedDate date={post.data.date} />
                    </span>
                    <a
                      href={`/blog/${post.id}`}
                      class="text-sm text-black hover:underline dark:text-white"
                    >
                      {post.data.title}
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-400">No posts yet.</p>
          )}
        </div>
      </div>
    </section>
  </Container>

  <!-- ─── 3. RECENT PROJECTS ────────────────────────────────────────────── -->
  <Container>
    <section class="py-14">
      <div class="mb-8">
        <h2 class="font-semibold text-black dark:text-white">Recent Projects</h2>
        <a
          href="/projects"
          class="mt-2 inline-block text-xs text-gray-400 transition-colors hover:text-black dark:hover:text-white"
        >
          view all →
        </a>
      </div>
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          {projects.map((project, i) => {
            const rotations = ["-rotate-2", "rotate-1", "-rotate-1"];
            const rot = rotations[i % 3];
            return (
              <a
                href={`/projects/${project.id}`}
                class={`block ${rot} transition-transform duration-300 hover:rotate-0`}
              >
                <!-- Polaroid card -->
                <div class="bg-white p-3 pb-10 shadow-lg dark:bg-neutral-100">
                  {project.data.cover ? (
                    <img
                      src={project.data.cover}
                      alt={project.data.title}
                      class="aspect-square w-full object-cover"
                    />
                  ) : (
                    <div class="aspect-square w-full bg-gray-200 flex items-center justify-center">
                      <span class="text-gray-400 text-xs select-none">no image</span>
                    </div>
                  )}
                  <!-- Handwritten-style date using Caveat -->
                  <p class="mt-3 text-center text-sm text-gray-500" style="font-family: 'Caveat', cursive; font-size: 1rem;">
                    <FormattedDate date={project.data.date} />
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="text-sm text-gray-400">No projects yet.</p>
      )}
    </section>
  </Container>

  <!-- ─── 4. DESK SCENE ─────────────────────────────────────────────────── -->
  <section class="relative w-full overflow-hidden" style="aspect-ratio: 16/7; min-height: 260px;">
    <!-- REPLACE WITH IMAGE: put desk illustration at public/images/desk-bg.jpg -->
    <!-- <div class="absolute inset-0 bg-gray-100 dark:bg-neutral-800 flex items-center justify-center">
      <span class="text-gray-400 text-xs select-none">desk scene illustration — replace with image</span>
    </div> -->
    <img src="/images/desk-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />

    <!--
      Desk objects: put colored PNGs in public/images/desk/
      Each is grayscale by default, colors on hover (CSS only, no JS)
    -->

    <!-- lamp: REPLACE WITH IMAGE public/images/desk/lamp.png -->
    <img
      src="/images/desk/lamp.png"
      alt="lamp"
      class="desk-object absolute"
      style="top: 15%; left: 12%; width: 8%;"
    />
    <!-- monitor: REPLACE WITH IMAGE public/images/desk/monitor.png -->
    <img
      src="/images/desk/monitor.png"
      alt="monitor"
      class="desk-object absolute"
      style="top: 8%; left: 38%; width: 18%;"
    />
    <!-- mug: REPLACE WITH IMAGE public/images/desk/mug.png -->
    <img
      src="/images/desk/mug.png"
      alt="mug"
      class="desk-object absolute"
      style="bottom: 28%; right: 28%; width: 7%;"
    />
    <!-- pencil cup: REPLACE WITH IMAGE public/images/desk/pencil-cup.png -->
    <img
      src="/images/desk/pencil-cup.png"
      alt="pencil cup"
      class="desk-object absolute"
      style="bottom: 24%; right: 18%; width: 6%;"
    />
  </section>

  <!-- ─── 5. CONTACT ────────────────────────────────────────────────────── -->
  <Container>
    <section class="py-14 text-center">
      <h2 class="text-2xl font-semibold text-black dark:text-white">Contact Me!</h2>
      <div class="mt-4 flex flex-col items-center gap-2 text-sm text-gray-500">
        <a
          href={`mailto:${SITE.EMAIL}`}
          class="transition-colors hover:text-black hover:underline dark:hover:text-white"
        >
          {SITE.EMAIL}
        </a>
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-black hover:underline dark:hover:text-white"
        >
          LinkedIn
        </a>
      </div>
    </section>
  </Container>

  <!-- Marker used by CSS and script to detect homepage -->
  <div data-homepage hidden></div>

</Layout>

<script is:inline>
  // Force light mode on the homepage — runs immediately after preloadTheme()
  // and after each view-transition swap back to this page.
  function forceLight() {
    document.documentElement.classList.remove("dark");
  }

  forceLight();

  document.addEventListener("DOMContentLoaded", function () {
    // init() in Head.astro re-applies the user's stored theme synchronously.
    // A microtask queued here runs after all DOMContentLoaded handlers finish,
    // removing dark again before the first paint.
    Promise.resolve().then(forceLight);
  });

  document.addEventListener("astro:after-swap", function () {
    if (document.querySelector("[data-homepage]")) {
      Promise.resolve().then(forceLight);
    }
  });
</script>

<style>
  .desk-object {
    filter: grayscale(100%);
    transition: filter 0.3s;
  }
  .desk-object:hover {
    filter: grayscale(0%);
  }
</style>
